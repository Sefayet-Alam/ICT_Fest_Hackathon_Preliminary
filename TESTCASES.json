{
  "suite": "cowork-booking-api",
  "base_url": "http://localhost:8000",
  "notes": "Black-box cases derived from README business rules. IDs mirror TESTCASES.md. status: untested|pass|fail.",
  "cases": [
    {"id": "T-HEALTH", "title": "Health check", "category": "smoke", "rule": 16, "setup": "none", "method": "GET", "path": "/health", "headers": {}, "body": null, "expected_status": 200, "expected_response_shape": {"status": "ok"}, "expected_behavior": "Liveness endpoint returns ok", "failure_signal": "non-200 or wrong body", "notes": "", "status": "untested"},
    {"id": "T-REG-ADMIN", "title": "Register creates org admin", "category": "auth", "rule": 15, "setup": "none", "method": "POST", "path": "/auth/register", "headers": {"Content-Type": "application/json"}, "body": {"org_name": "acme2", "username": "alice", "password": "pw12345"}, "expected_status": 201, "expected_response_shape": {"user_id": "int", "org_id": "int", "username": "str", "role": "admin"}, "expected_behavior": "First user in unknown org becomes admin", "failure_signal": "role != admin", "notes": "", "status": "untested"},
    {"id": "T-REG-MEMBER", "title": "Join existing org as member", "category": "auth", "rule": 15, "setup": "org acme exists", "method": "POST", "path": "/auth/register", "headers": {"Content-Type": "application/json"}, "body": {"org_name": "acme", "username": "bob2", "password": "pw12345"}, "expected_status": 201, "expected_response_shape": {"role": "member"}, "expected_behavior": "Known org join = member", "failure_signal": "role != member", "notes": "", "status": "untested"},
    {"id": "T-REG-DUP", "title": "Duplicate username returns 409", "category": "auth", "rule": 15, "bug": "A4", "setup": "user exists", "method": "POST", "path": "/auth/register", "headers": {"Content-Type": "application/json"}, "body": {"org_name": "acme", "username": "bob", "password": "pw12345"}, "expected_status": 409, "expected_response_shape": {"code": "USERNAME_TAKEN"}, "expected_behavior": "Duplicate username in org rejected", "failure_signal": "200 or 500", "notes": "currently returns 200", "status": "untested"},
    {"id": "T-LOGIN-BAD", "title": "Bad credentials", "category": "auth", "rule": 8, "setup": "user exists", "method": "POST", "path": "/auth/login", "headers": {"Content-Type": "application/json"}, "body": {"org_name": "acme", "username": "bob", "password": "wrong"}, "expected_status": 401, "expected_response_shape": {"code": "INVALID_CREDENTIALS"}, "expected_behavior": "Wrong password rejected", "failure_signal": "other status", "notes": "", "status": "untested"},
    {"id": "T-JWT-EXP", "title": "Access token lifetime 900s", "category": "auth", "rule": 8, "bug": "A1", "setup": "login", "method": "DECODE", "path": "access_token", "headers": {}, "body": null, "expected_status": null, "expected_response_shape": {"exp_minus_iat": 900}, "expected_behavior": "exp - iat exactly 900 seconds", "failure_signal": "54000 or other", "notes": "decode JWT payload without verifying", "status": "untested"},
    {"id": "T-AUTH-LOGOUT", "title": "Logout invalidates token", "category": "auth", "rule": 8, "bug": "A2", "setup": "login", "method": "SEQUENCE", "path": "/auth/logout then GET /rooms", "headers": {"Authorization": "Bearer $ACCESS"}, "body": null, "expected_status": 401, "expected_response_shape": {}, "expected_behavior": "Reusing token after logout is 401", "failure_signal": "200 after logout", "notes": "", "status": "untested"},
    {"id": "T-AUTH-REFRESH-ROTATE", "title": "Refresh returns new pair", "category": "auth", "rule": 8, "setup": "login", "method": "POST", "path": "/auth/refresh", "headers": {"Content-Type": "application/json"}, "body": {"refresh_token": "$REFRESH"}, "expected_status": 200, "expected_response_shape": {"access_token": "str", "refresh_token": "str", "token_type": "bearer"}, "expected_behavior": "Rotates tokens", "failure_signal": "non-200", "notes": "", "status": "untested"},
    {"id": "T-AUTH-REFRESH-REUSE", "title": "Refresh single-use", "category": "auth", "rule": 8, "bug": "A5", "setup": "refreshed once", "method": "POST", "path": "/auth/refresh", "headers": {"Content-Type": "application/json"}, "body": {"refresh_token": "$OLD_REFRESH"}, "expected_status": 401, "expected_response_shape": {}, "expected_behavior": "Old refresh token rejected after use", "failure_signal": "200 (reusable)", "notes": "", "status": "untested"},
    {"id": "T-TZ-OFFSET", "title": "Offset input converted to UTC", "category": "time", "rule": 1, "bug": "T1", "setup": "admin, room", "method": "SEQUENCE", "path": "POST /bookings offset then GET availability", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "2026-12-01T12:00:00+06:00", "end_time": "2026-12-01T13:00:00+06:00"}, "expected_status": 201, "expected_response_shape": {"start_time_utc": "2026-12-01T06:00:00+00:00"}, "expected_behavior": "12:00+06:00 stored/echoed as 06:00Z", "failure_signal": "echoes 12:00 (offset dropped)", "notes": "", "status": "untested"},
    {"id": "T-WIN-PAST", "title": "Past start rejected, no grace", "category": "booking", "rule": 2, "bug": "B2", "setup": "admin, room", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<now-60s>", "end_time": "<now+3540s>"}, "expected_status": 400, "expected_response_shape": {"code": "INVALID_BOOKING_WINDOW"}, "expected_behavior": "Any past start rejected", "failure_signal": "201", "notes": "current 300s grace", "status": "untested"},
    {"id": "T-WIN-ZERO", "title": "Zero duration rejected", "category": "booking", "rule": 2, "bug": "B3", "setup": "admin, room", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<t>", "end_time": "<t>"}, "expected_status": 400, "expected_response_shape": {"code": "INVALID_BOOKING_WINDOW"}, "expected_behavior": "end==start rejected", "failure_signal": "201 price 0", "notes": "", "status": "untested"},
    {"id": "T-WIN-NEG", "title": "end before start rejected", "category": "booking", "rule": 2, "bug": "B3", "setup": "admin, room", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<t+1h>", "end_time": "<t>"}, "expected_status": 400, "expected_response_shape": {"code": "INVALID_BOOKING_WINDOW"}, "expected_behavior": "end<start rejected", "failure_signal": "201/negative price", "notes": "", "status": "untested"},
    {"id": "T-WIN-9H", "title": "Duration 9h rejected", "category": "booking", "rule": 2, "setup": "admin, room", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<t>", "end_time": "<t+9h>"}, "expected_status": 400, "expected_response_shape": {"code": "INVALID_BOOKING_WINDOW"}, "expected_behavior": "max 8h", "failure_signal": "201", "notes": "", "status": "untested"},
    {"id": "T-WIN-HALF", "title": "Non-whole hours rejected", "category": "booking", "rule": 2, "setup": "admin, room", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<t>", "end_time": "<t+90m>"}, "expected_status": 400, "expected_response_shape": {"code": "INVALID_BOOKING_WINDOW"}, "expected_behavior": "whole hours only", "failure_signal": "201", "notes": "", "status": "untested"},
    {"id": "T-PRICE", "title": "Price = rate x hours", "category": "booking", "rule": 2, "setup": "room rate 1000", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<t>", "end_time": "<t+2h>"}, "expected_status": 201, "expected_response_shape": {"price_cents": 2000}, "expected_behavior": "2h x 1000 = 2000", "failure_signal": "wrong price", "notes": "", "status": "untested"},
    {"id": "T-CONF-OVERLAP", "title": "Overlap rejected", "category": "booking", "rule": 3, "setup": "booking 10-12 exists", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<10:30>", "end_time": "<13:00>"}, "expected_status": 409, "expected_response_shape": {"code": "ROOM_CONFLICT"}, "expected_behavior": "true overlap rejected", "failure_signal": "201", "notes": "", "status": "untested"},
    {"id": "T-CONF-BACK2BACK", "title": "Back-to-back allowed", "category": "booking", "rule": 3, "bug": "B1", "setup": "booking 10-11 exists", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": {"room_id": "$ROOM", "start_time": "<11:00>", "end_time": "<12:00>"}, "expected_status": 201, "expected_response_shape": {}, "expected_behavior": "adjacent bookings allowed", "failure_signal": "409", "notes": "key bug", "status": "untested"},
    {"id": "T-QUOTA", "title": "4th booking in window rejected", "category": "booking", "rule": 4, "setup": "3 confirmed in (now,+24h]", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $MEMBER"}, "body": {"room_id": "$ROOM", "start_time": "<in-window>", "end_time": "<+1h>"}, "expected_status": 409, "expected_response_shape": {"code": "QUOTA_EXCEEDED"}, "expected_behavior": "max 3 in window", "failure_signal": "201", "notes": "", "status": "untested"},
    {"id": "T-QUOTA-OUTSIDE", "title": "Beyond 24h not quota-limited", "category": "booking", "rule": 4, "setup": "3 in window", "method": "POST", "path": "/bookings", "headers": {"Authorization": "Bearer $MEMBER"}, "body": {"room_id": "$ROOM", "start_time": "<now+30h>", "end_time": "<+1h>"}, "expected_status": 201, "expected_response_shape": {}, "expected_behavior": "window is (now,+24h]", "failure_signal": "409", "notes": "", "status": "untested"},
    {"id": "T-LIST-ORDER", "title": "List ascending by start_time", "category": "listing", "rule": 11, "bug": "B5a", "setup": ">=2 bookings", "method": "GET", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"items": "ascending start_time"}, "expected_behavior": "asc start_time, ties asc id", "failure_signal": "descending", "notes": "", "status": "untested"},
    {"id": "T-LIST-PAGE1", "title": "Page 1 returns first slice", "category": "listing", "rule": 11, "bug": "B5b", "setup": ">=11 bookings", "method": "GET", "path": "/bookings?page=1&limit=10", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"items[0]": "first of ordering"}, "expected_behavior": "items [0,10)", "failure_signal": "skips first 10", "notes": "off-by-one", "status": "untested"},
    {"id": "T-LIST-LIMIT", "title": "Limit honored", "category": "listing", "rule": 11, "bug": "B5c", "setup": ">=3 bookings", "method": "GET", "path": "/bookings?limit=2", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"items_len": 2}, "expected_behavior": "returns exactly limit", "failure_signal": "returns up to 10", "notes": "", "status": "untested"},
    {"id": "T-LIST-TOTAL", "title": "total equals full count", "category": "listing", "rule": 11, "setup": "N bookings", "method": "GET", "path": "/bookings", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"total": "N"}, "expected_behavior": "total is unpaginated count", "failure_signal": "wrong total", "notes": "", "status": "untested"},
    {"id": "T-VIS-IDOR-GET", "title": "Member cannot read other's booking", "category": "authz", "rule": 10, "bug": "B6", "setup": "bob books; alice is member", "method": "GET", "path": "/bookings/{bobBookingId}", "headers": {"Authorization": "Bearer $ALICE"}, "body": null, "expected_status": 404, "expected_response_shape": {"code": "BOOKING_NOT_FOUND"}, "expected_behavior": "other member's id is 404", "failure_signal": "200", "notes": "IDOR", "status": "untested"},
    {"id": "T-VIS-ADMIN-GET", "title": "Admin reads any org booking", "category": "authz", "rule": 10, "setup": "bob books", "method": "GET", "path": "/bookings/{bobBookingId}", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {}, "expected_behavior": "admin sees org-wide", "failure_signal": "404", "notes": "", "status": "untested"},
    {"id": "T-DETAIL-STARTTIME", "title": "Detail start_time correct", "category": "contract", "rule": 0, "bug": "B7", "setup": "one booking", "method": "GET", "path": "/bookings/{id}", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"start_time": "== booked start"}, "expected_behavior": "start_time is the booking start", "failure_signal": "equals created_at", "notes": "", "status": "untested"},
    {"id": "T-DETAIL-REFUNDS", "title": "Detail includes refunds array", "category": "contract", "rule": 0, "setup": "cancelled booking", "method": "GET", "path": "/bookings/{id}", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refunds": [{"amount_cents": "int", "status": "str", "processed_at": "str"}]}, "expected_behavior": "refunds present with shape", "failure_signal": "missing/wrong shape", "notes": "", "status": "untested"},
    {"id": "T-REFUND-100", "title": ">=48h notice 100%", "category": "refund", "rule": 6, "setup": "booking start now+50h", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refund_percent": 100}, "expected_behavior": "full refund", "failure_signal": "other", "notes": "", "status": "untested"},
    {"id": "T-REFUND-48", "title": "Exactly 48h is 100%", "category": "refund", "rule": 6, "bug": "B8a", "setup": "booking start now+48h", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refund_percent": 100}, "expected_behavior": "boundary inclusive", "failure_signal": "50", "notes": "boundary", "status": "untested"},
    {"id": "T-REFUND-50", "title": "24-48h is 50%", "category": "refund", "rule": 6, "setup": "booking start now+30h", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refund_percent": 50}, "expected_behavior": "half refund", "failure_signal": "other", "notes": "", "status": "untested"},
    {"id": "T-REFUND-0", "title": "<24h is 0%", "category": "refund", "rule": 6, "bug": "B8b", "setup": "booking start now+1h", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refund_percent": 0}, "expected_behavior": "no refund", "failure_signal": "50", "notes": "key bug", "status": "untested"},
    {"id": "T-REFUND-ROUND", "title": "Half-cent rounds up", "category": "refund", "rule": 6, "bug": "B9", "setup": "price 1001, 50% tier", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"refund_amount_cents": 501}, "expected_behavior": "50% of 1001 = 501", "failure_signal": "500", "notes": "", "status": "untested"},
    {"id": "T-REFUND-CONSISTENT", "title": "Response equals RefundLog", "category": "refund", "rule": 6, "bug": "B9", "setup": "any cancel", "method": "COMPARE", "path": "cancel.refund_amount_cents vs GET /bookings/{id}.refunds[0].amount_cents", "headers": {}, "body": null, "expected_status": null, "expected_response_shape": {"equal": true}, "expected_behavior": "stored == returned", "failure_signal": "differ", "notes": "", "status": "untested"},
    {"id": "T-CANCEL-DUP", "title": "Re-cancel is 409", "category": "refund", "rule": 6, "setup": "cancelled booking", "method": "POST", "path": "/bookings/{id}/cancel", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 409, "expected_response_shape": {"code": "ALREADY_CANCELLED"}, "expected_behavior": "idempotent guard", "failure_signal": "other", "notes": "", "status": "untested"},
    {"id": "T-CANCEL-AUTH", "title": "Non-owner member cannot cancel", "category": "authz", "rule": 6, "setup": "bob books; alice member", "method": "POST", "path": "/bookings/{bobBookingId}/cancel", "headers": {"Authorization": "Bearer $ALICE"}, "body": null, "expected_status": 404, "expected_response_shape": {"code": "BOOKING_NOT_FOUND"}, "expected_behavior": "only owner or admin", "failure_signal": "200", "notes": "", "status": "untested"},
    {"id": "T-AVAIL", "title": "Availability lists busy sorted", "category": "rooms", "rule": 13, "setup": "booking on date D", "method": "GET", "path": "/rooms/{id}/availability?date=D", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"busy": "sorted intervals"}, "expected_behavior": "busy intervals ascending", "failure_signal": "missing/unsorted", "notes": "", "status": "untested"},
    {"id": "T-AVAIL-STALE", "title": "Cancel updates availability", "category": "rooms", "rule": 13, "bug": "RM1", "setup": "book, GET avail (caches), cancel", "method": "GET", "path": "/rooms/{id}/availability?date=D", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"busy": "excludes cancelled"}, "expected_behavior": "reflects current state", "failure_signal": "still busy (stale cache)", "notes": "", "status": "untested"},
    {"id": "T-REPORT", "title": "Usage report per room", "category": "admin", "rule": 12, "setup": "bookings in range", "method": "GET", "path": "/admin/usage-report?from=F&to=T", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"rooms": [{"room_id": "int", "confirmed_bookings": "int", "revenue_cents": "int"}]}, "expected_behavior": "includes zero-booking rooms", "failure_signal": "missing rooms/wrong sums", "notes": "", "status": "untested"},
    {"id": "T-REPORT-STALE", "title": "Create updates report", "category": "admin", "rule": 12, "bug": "AD1", "setup": "GET report (caches), create booking", "method": "GET", "path": "/admin/usage-report?from=F&to=T", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"reflects_new_booking": true}, "expected_behavior": "immediate current state", "failure_signal": "stale (unchanged)", "notes": "", "status": "untested"},
    {"id": "T-REPORT-EXCL-CANCEL", "title": "Cancelled excluded from report", "category": "admin", "rule": 12, "setup": "cancelled booking", "method": "GET", "path": "/admin/usage-report?from=F&to=T", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"excludes_cancelled": true}, "expected_behavior": "only confirmed counted", "failure_signal": "counted", "notes": "", "status": "untested"},
    {"id": "T-STATS-DERIVED", "title": "Stats equal DB-derived", "category": "rooms", "rule": 14, "bug": "S1", "setup": "create then cancel", "method": "GET", "path": "/rooms/{id}/stats", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"total_confirmed_bookings": "matches DB", "total_revenue_cents": "matches DB"}, "expected_behavior": "always equals bookings-derived values", "failure_signal": "drift after cancel/concurrency", "notes": "", "status": "untested"},
    {"id": "T-EXPORT-HEADER", "title": "CSV header exact", "category": "admin", "rule": 0, "setup": "any", "method": "GET", "path": "/admin/export", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 200, "expected_response_shape": {"header": "id,reference_code,room_id,user_id,start_time,end_time,status,price_cents"}, "expected_behavior": "exact header order", "failure_signal": "wrong header", "notes": "", "status": "untested"},
    {"id": "T-EXPORT-CROSSORG", "title": "Export cannot leak other org", "category": "security", "rule": 9, "bug": "EX1", "setup": "2 orgs, room in org2", "method": "GET", "path": "/admin/export?include_all=true&room_id={org2room}", "headers": {"Authorization": "Bearer $ORG1_ADMIN"}, "body": null, "expected_status": 404, "expected_response_shape": {"code": "ROOM_NOT_FOUND"}, "expected_behavior": "cross-org room is 404, no rows leaked", "failure_signal": "org2 bookings returned", "notes": "security", "status": "untested"},
    {"id": "T-TENANT-ROOM", "title": "Cross-org room id 404", "category": "security", "rule": 9, "setup": "room in org2", "method": "GET", "path": "/rooms/{org2room}/availability?date=D", "headers": {"Authorization": "Bearer $ORG1_USER"}, "body": null, "expected_status": 404, "expected_response_shape": {"code": "ROOM_NOT_FOUND"}, "expected_behavior": "cross-org resource behaves as non-existent", "failure_signal": "200/leak", "notes": "", "status": "untested"},
    {"id": "T-ADMIN-ONLY-CREATE", "title": "Member cannot create room", "category": "authz", "rule": 0, "setup": "member token", "method": "POST", "path": "/rooms", "headers": {"Authorization": "Bearer $MEMBER"}, "body": {"name": "X", "capacity": 2, "hourly_rate_cents": 500}, "expected_status": 403, "expected_response_shape": {"code": "FORBIDDEN"}, "expected_behavior": "admin-only", "failure_signal": "201", "notes": "", "status": "untested"},
    {"id": "T-REF-UNIQUE", "title": "Reference codes unique under concurrency", "category": "concurrency", "rule": 7, "bug": "REF1", "setup": "admin, room", "method": "CONCURRENT", "path": "POST /bookings x10 distinct slots", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": 201, "expected_response_shape": {"reference_codes": "all distinct"}, "expected_behavior": "no duplicate codes", "failure_signal": "duplicates", "notes": "needs concurrency runner", "status": "untested"},
    {"id": "T-CONF-CONC", "title": "No double-book under concurrency", "category": "concurrency", "rule": 3, "bug": "B-CONC", "setup": "admin, room", "method": "CONCURRENT", "path": "POST /bookings x5 identical slot", "headers": {"Authorization": "Bearer $ADMIN"}, "body": null, "expected_status": null, "expected_response_shape": {"success_count": 1}, "expected_behavior": "exactly one 201, rest 409", "failure_signal": ">=2 success", "notes": "", "status": "untested"},
    {"id": "T-QUOTA-CONC", "title": "Quota holds under concurrency", "category": "concurrency", "rule": 4, "bug": "B-CONC", "setup": "member at 3-in-window", "method": "CONCURRENT", "path": "POST /bookings x2 (4th,5th)", "headers": {"Authorization": "Bearer $MEMBER"}, "body": null, "expected_status": null, "expected_response_shape": {"confirmed_in_window_max": 3}, "expected_behavior": "quota not exceeded", "failure_signal": ">3 confirmed", "notes": "", "status": "untested"},
    {"id": "T-RATE", "title": "Rate limit 20 per 60s", "category": "ratelimit", "rule": 5, "setup": "member", "method": "SEQUENCE", "path": "POST /bookings x21 within 60s", "headers": {"Authorization": "Bearer $MEMBER"}, "body": null, "expected_status": 429, "expected_response_shape": {"code": "RATE_LIMITED"}, "expected_behavior": "21st rejected; all requests count", "failure_signal": "all 201", "notes": "", "status": "untested"},
    {"id": "T-RATE-CONC", "title": "Rate limit under concurrency", "category": "concurrency", "rule": 5, "bug": "RL1", "setup": "member", "method": "CONCURRENT", "path": "POST /bookings x30", "headers": {"Authorization": "Bearer $MEMBER"}, "body": null, "expected_status": null, "expected_response_shape": {"passed_max": 20}, "expected_behavior": "at most 20 pass", "failure_signal": ">20 pass", "notes": "", "status": "untested"},
