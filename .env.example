# CoWork API configuration. Copy to `.env` and adjust; do NOT commit real secrets.
# Both variables have safe in-code defaults, so the app also runs with no .env at all.

# Secret used to sign/verify JWTs (HS256). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# SQLAlchemy database URL. Default is a local SQLite file.
# Docker compose uses sqlite:////app/data/cowork.db (persisted volume).
DATABASE_URL=sqlite:///./cowork.db
